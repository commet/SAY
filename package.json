    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "5.0.5",
    "@types/node": "22.19.11",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  }
}
