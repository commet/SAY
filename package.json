{
  "name": "say-mcp",
  "version": "1.0.0",
  "description": "Privacy-first family notice operations agent for PlayMCP",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
